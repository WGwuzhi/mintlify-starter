{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "autClaw Docs",
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#1D4ED8"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "指南",
        "icon": "book-open",
        "groups": [
          {
            "group": "开始使用",
            "pages": [
              "index",
              "getting-started/deploy",
              "getting-started/upgrade",
              "getting-started/runtime-paths"
            ]
          },
          {
            "group": "运维",
            "pages": [
              "operations/docker",
              "operations/chromium-cjk"
            ]
          }
        ]
      },
      {
        "tab": "插件开发",
        "icon": "puzzle",
        "groups": [
          {
            "group": "Plugin SDK",
            "pages": [
              "plugin-sdk/overview",
              "plugin-sdk/manifest",
              "plugin-sdk/javascript",
              "plugin-sdk/python",
              "plugin-sdk/media",
              "plugin-sdk/ai"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/WGwuzhi/autClaw",
          "icon": "github"
        },
        {
          "anchor": "Source",
          "href": "https://github.com/WGwuzhi/autClaw-Codebase",
          "icon": "code"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/WGwuzhi/autClaw"
      }
    ],
    "primary": {
      "type": "button",
      "label": "部署 autClaw",
      "href": "/getting-started/deploy"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/WGwuzhi/autClaw"
    }
  }
}
