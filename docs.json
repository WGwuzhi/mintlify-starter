{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "autClaw Docs",
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#1D4ED8"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "languages": [
      {
        "language": "cn",
        "default": true,
        "navbar": {
          "links": [
            {
              "label": "GitHub",
              "href": "https://github.com/WGwuzhi/autClaw"
            }
          ],
          "primary": {
            "type": "button",
            "label": "部署 autClaw",
            "href": "/cn/getting-started/deploy"
          }
        },
        "tabs": [
          {
            "tab": "指南",
            "icon": "book-open",
            "groups": [
              {
                "group": "开始使用",
                "pages": [
                  "cn/index",
                  "cn/getting-started/deploy",
                  "cn/getting-started/upgrade",
                  "cn/getting-started/runtime-paths"
                ]
              },
              {
                "group": "运维",
                "pages": [
                  "cn/operations/docker",
                  "cn/operations/chromium-cjk"
                ]
              }
            ]
          },
          {
            "tab": "插件开发",
            "icon": "puzzle",
            "groups": [
              {
                "group": "Plugin SDK",
                "pages": [
                  "cn/plugin-sdk/overview",
                  "cn/plugin-sdk/manifest",
                  "cn/plugin-sdk/javascript",
                  "cn/plugin-sdk/python",
                  "cn/plugin-sdk/media",
                  "cn/plugin-sdk/ai"
                ]
              }
            ]
          }
        ]
      },
      {
        "language": "en",
        "navbar": {
          "links": [
            {
              "label": "GitHub",
              "href": "https://github.com/WGwuzhi/autClaw"
            }
          ],
          "primary": {
            "type": "button",
            "label": "Deploy autClaw",
            "href": "/en/getting-started/deploy"
          }
        },
        "tabs": [
          {
            "tab": "Guides",
            "icon": "book-open",
            "groups": [
              {
                "group": "Getting started",
                "pages": [
                  "en/index",
                  "en/getting-started/deploy",
                  "en/getting-started/upgrade",
                  "en/getting-started/runtime-paths"
                ]
              },
              {
                "group": "Operations",
                "pages": [
                  "en/operations/docker",
                  "en/operations/chromium-cjk"
                ]
              }
            ]
          },
          {
            "tab": "Plugin development",
            "icon": "puzzle",
            "groups": [
              {
                "group": "Plugin SDK",
                "pages": [
                  "en/plugin-sdk/overview",
                  "en/plugin-sdk/manifest",
                  "en/plugin-sdk/javascript",
                  "en/plugin-sdk/python",
                  "en/plugin-sdk/media",
                  "en/plugin-sdk/ai"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/WGwuzhi/autClaw"
      }
    ],
    "primary": {
      "type": "button",
      "label": "部署 autClaw",
      "href": "/cn/getting-started/deploy"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/WGwuzhi/autClaw"
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/cn"
    },
    {
      "source": "/index",
      "destination": "/cn"
    },
    {
      "source": "/getting-started/:slug*",
      "destination": "/cn/getting-started/:slug*"
    },
    {
      "source": "/operations/:slug*",
      "destination": "/cn/operations/:slug*"
    },
    {
      "source": "/plugin-sdk/:slug*",
      "destination": "/cn/plugin-sdk/:slug*"
    }
  ]
}
